{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Engine (linux-debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceRoot}/build/engine_debug/engine/main/ntt-engine",
			"preLaunchTask": "Build Engine (linux-debug)",
			"cwd": "${workspaceRoot}/build/engine_debug/engine/main"
		},
		{
			"name": "Analyze python",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/analyze/main.py",
			"console": "integratedTerminal"
		},
		{
			"name": "Analyze test",
			"type": "debugpy",
			"request": "launch",
			"module": "pytest",
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal"
		}
	]
}
