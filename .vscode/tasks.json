{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Engine (linux-debug)",
			"command": "cmake",
			"type": "shell",
			"args": ["--build", "${workspaceRoot}/build/debug"],
			"problemMatcher": ["$tsc"],
			"presentation": {
				"reveal": "always"
			},
			"group": "build"
		},
		{
			"label": "Build Unittest (linux)",
			"command": "cmake",
			"type": "shell",
			"args": ["--build", "${workspaceRoot}/build/unittest"],
			"problemMatcher": ["$tsc"],
			"presentation": {
				"reveal": "always"
			},
			"group": "build"
		}
	]
}
