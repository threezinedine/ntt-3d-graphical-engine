#ifndef UNIFORM_TYPE_DEF
#define UNIFORM_TYPE_DEF(type, name, uppercase, glType)
#endif

UNIFORM_TYPE_DEF(float, Float , FLOAT , GL_FLOAT)
UNIFORM_TYPE_DEF(Vec2f, Float2, FLOAT2, GL_FLOAT_VEC2)
UNIFORM_TYPE_DEF(Vec3f, Float3, FLOAT3, GL_FLOAT_VEC3)
UNIFORM_TYPE_DEF(Vec4f, Float4, FLOAT4, GL_FLOAT_VEC4)