CONSOLE_COLOR_OPTION(BLUE, "034")
CONSOLE_COLOR_OPTION(MAGENTA, "035")
CONSOLE_COLOR_OPTION(CYAN, "036")
CONSOLE_COLOR_OPTION(WHITE, "037")
CONSOLE_COLOR_OPTION_END(COUNT)