#ifndef LOGGING_LEVEL_OPTION
#define LOGGING_LEVEL_OPTION(option, color)
#endif

#ifndef LOGGING_LEVEL_OPTION_END
#define LOGGING_LEVEL_OPTION_END(option)
#endif

LOGGING_LEVEL_OPTION(TRACE, BLACK)
LOGGING_LEVEL_OPTION(DEBUG, BLUE)
LOGGING_LEVEL_OPTION(INFO , GREEN)
LOGGING_LEVEL_OPTION(WARN , YELLOW)
LOGGING_LEVEL_OPTION(ERROR, RED)
LOGGING_LEVEL_OPTION(FATAL, MAGENTA)