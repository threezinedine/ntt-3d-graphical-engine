{
	"common": {
		"inherit": [],
		"options": []
	},
	"only-engine": {
		"inherit": ["common"],
		"options": ["NTT_EDITOR=0", "NTT_ENGINE=1", "NTT_UNITTEST=0"]
	},
	"only-editor": {
		"inherit": ["common"],
		"options": ["NTT_EDITOR=1", "NTT_ENGINE=0", "NTT_UNITTEST=0"]
	},
	"only-unittest": {
		"inherit": ["common"],
		"options": [
			"NTT_EDITOR=0",
			"NTT_ENGINE=0",
			"NTT_UNITTEST=1",
			"NTT_ENABLE_ASSERTION=0",
			"NTT_LOG_MEMORY=0"
		]
	},
	"editor-and-engine": {
		"inherit": ["common"],
		"options": ["NTT_EDITOR=1", "NTT_ENGINE=1", "NTT_UNITTEST=0"]
	},
	"debug": {
		"inherit": ["editor-and-engine"],
		"options": [],
		"command": "cmake -B build/debug -Wno-dev -DCMAKE_BUILD_TYPE=Debug {{ options }}"
	},
	"release": {
		"inherit": ["common"],
		"options": ["NTT_ENABLE_ASSERTION=0"],
		"command": "cmake -B build/release -Wno-dev -DCMAKE_BUILD_TYPE=Release {{ options }}"
	},
	"web-debug": {
		"inherit": ["common"],
		"options": [],
		"command": "emcmake cmake -B build/web_debug -Wno-dev -DCMAKE_BUILD_TYPE=Debug {{ options }}"
	},
	"unittest": {
		"inherit": ["only-unittest"],
		"options": [],
		"command": "cmake -B build/unittest -Wno-dev -DCMAKE_BUILD_TYPE=Debug {{ options }}"
	}
}
